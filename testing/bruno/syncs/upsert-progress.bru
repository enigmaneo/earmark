meta {
  name: Upsert Progress
  type: http
  seq: 1
}

put {
  url: {{base_url}}/syncs/progress
  body: json
  auth: basic
}

auth:basic {
  username: {{username}}
  password: {{password}}
}

body:json {
  {
    "document": "{{document_id}}",
    "progress": "epubcfi(/6/4[chap01ref]!/4[body01]/10[para05]/2/1:3)",
    "percentage": 0.25,
    "device": "My Kobo",
    "device_id": "kobo-device-001",
    "metadata": {
      "filename": "test-book.epub",
      "title": "Test Book",
      "authors": "Test Author"
    }
  }
}
