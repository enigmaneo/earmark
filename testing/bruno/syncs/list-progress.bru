meta {
  name: List Progress
  type: http
  seq: 2
}

get {
  url: {{base_url}}/syncs/progress?document={{document_id}}&page=1&per_page=50
  body: none
  auth: none
}

params:query {
  document: {{document_id}}
  page: 1
  per_page: 50
}

headers {
  x-auth-user: {{username}}
  x-auth-key: {{password_hash}}
}
