meta {
  name: Create User
  type: http
  seq: 1
}

post {
  url: {{base_url}}/users/create
  body: json
  auth: none
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password_hash}}"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar('username', res.body.username);
  }
}
