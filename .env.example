DATABASE_URL=sqlite+aiosqlite:///./earmark.db

SECRET_KEY=change-me-in-production

AUDIOBOOKSHELF_URL=http://localhost:13378
AUDIOBOOKSHELF_API_KEY=

SYNC_INTERVAL_SECONDS=300

EBOOK_LOCAL_ROOT=.

# TIMEZONE=America/New_York  # IANA timezone name for storing timestamps

# LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR
# LOG_PRETTY=true  # enable rich colored log output (dev only)

# --- Alignment (WhisperX) ---
# WHISPER_MODEL=tiny.en          # tiny.en | base.en | small.en | medium.en | large-v3
# WHISPER_DEVICE=cpu             # cpu | cuda | mps
# WHISPER_COMPUTE_TYPE=int8      # int8 | float16 | float32
# WHISPER_BATCH_SIZE=4           # lower (e.g. 1 or 2) on low-RAM hosts
# WHISPER_CHUNK_SECONDS=600      # audio chunk size; lower on low-RAM hosts to cut peak RAM

# --- Docker ---
# External port for the web UI
PORT=7070
# Public URL of the app — used by SvelteKit for secure cookies
ORIGIN=http://localhost:7070
