DATABASE_URL=sqlite+aiosqlite:///./earmark.db

# Signs JWTs. Use a strong random value in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# Comma-separated list of origins allowed by CORS (the SvelteKit dev/app origin).
# CORS_ORIGINS=http://localhost:5173

AUDIOBOOKSHELF_URL=http://localhost:13378
AUDIOBOOKSHELF_API_KEY=

SYNC_INTERVAL_SECONDS=300
# Min seconds since ABS lastUpdate before pushing audio progress to KOSync. Holds back the
# write while an audiobook is actively playing so a session yields one KOSync entry, not one
# per sync cycle.
SYNC_ABS_IDLE_SECONDS=360

EBOOK_LOCAL_ROOT=.

# --- Calibre Web (OPDS) — optional ebook source for mappings ---
# CWA_URL=http://calibre.local:8083
# CWA_USERNAME=
# CWA_PASSWORD=

# TIMEZONE=America/New_York  # IANA timezone for displaying timestamps in the UI

# LOG_LEVEL=INFO        # DEBUG, INFO, WARNING, ERROR
# LOG_PRETTY=true       # enable rich colored log output (dev only)
# LOG_REQUESTS=false    # log every incoming request (method, path, status, duration, body)

# --- File logging (JSON lines, rotated on disk; also tunable from the Settings tab) ---
# LOG_DIR=./logs                  # directory the log file is written to (env only)
# LOG_ROTATION_STRATEGY=size      # size (RotatingFileHandler) | time (TimedRotatingFileHandler)
# LOG_MAX_SIZE_MB=10              # size strategy: rotate when the file exceeds this many MB
# LOG_ROTATION_WHEN=midnight      # time strategy: TimedRotatingFileHandler `when` value
# LOG_BACKUP_COUNT=5             # how many rotated files to keep

# --- Alignment (faster-whisper) ---
# WHISPER_MODEL=tiny.en          # tiny.en | base.en | small.en | medium.en | large-v3
# WHISPER_DEVICE=cpu             # cpu | cuda | mps
# WHISPER_COMPUTE_TYPE=int8      # int8 | float16 | float32
# WHISPER_CHUNK_SECONDS=600      # audio chunk size; lower on low-RAM hosts to cut peak RAM
# WHISPER_CPU_THREADS=4          # threads per faster-whisper inference; set to host CPU count

# --- Docker ---
# External port for the web UI
PORT=7070
# Public URL of the app — used by SvelteKit for secure cookies
ORIGIN=http://localhost:7070
